# hyper98 environment variables. Copy to .env.local and fill in.
# All of these are NEXT_PUBLIC_* — they ship to the browser.

# WalletConnect project ID (for ConnectKit). Create at https://cloud.reown.com/
# Optional — wallet connect still works without a project ID, but you'll see
# warnings and some WC-specific wallets won't surface.
NEXT_PUBLIC_WC_PROJECT_ID=

# Hyperliquid network. One of "testnet" | "mainnet". Anything else falls
# back to "testnet". Flipping this requires a redeploy/rebuild — the client
# bundle inlines NEXT_PUBLIC_* values at build time.
NEXT_PUBLIC_HL_NETWORK=testnet

# Comma-separated lowercase 0x addresses allowed to open Admin.exe.
# The Start menu hides the Admin entry when the connected wallet is not in
# this list; the Admin window itself also re-checks before rendering.
# Empty = no admins (the Admin window stays inaccessible from the Start menu).
NEXT_PUBLIC_ADMIN_ADDRESSES=
